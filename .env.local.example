# Resend API Key – von resend.com/api-keys
RESEND_API_KEY=re_...

# Deine E-Mail-Adresse für die wöchentliche Benachrichtigung
EMAIL_TO=deine@email.de

# Absender-Adresse (optional, Standard: onboarding@resend.dev)
# Für eigene Domain: erst Domain in Resend verifizieren
# EMAIL_FROM=mensa@deinedomain.de

# Geheimer Token für den Cron-Endpunkt (beliebiger langer zufälliger String)
CRON_SECRET=dein-geheimer-token

# Öffentliche URL der App (für E-Mail-Links)
NEXT_PUBLIC_URL=https://mensa-check.vercel.app
